{
  "name": "ide-switcher",
  "displayName": "IDEswitcher - Jump to IntelliJ",
  "description": "Jump from this editor to IntelliJ IDEA with current file and cursor position",
  "version": "1.7.0",
  "publisher": "melomei",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MeloMei/IDEswitcher"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onCommand:ideSwitcher.jumpToIntelliJ"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [{
      "command": "ideSwitcher.jumpToIntelliJ",
      "title": "Jump to IntelliJ IDEA (⇧⌥O)"
    }],
    "keybindings": [{
      "command": "ideSwitcher.jumpToIntelliJ",
      "key": "shift+alt+o",
      "mac": "shift+alt+o"
    }],
    "menus": {
      "editor/context": [{
        "command": "ideSwitcher.jumpToIntelliJ",
        "group": "navigation",
        "when": "editorTextFocus"
      }]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "vitest": "^3.2.0"
  }
}